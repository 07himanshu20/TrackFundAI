# =============================================================================
# TrackFundAI backend — env template. COMMITTED to git as a blueprint.
# ---------------------------------------------------------------------------
# Real secrets live in:
#     backend/.env.local           (this Mac)
#     backend/.env.development     (dev / integration server)
#     backend/.env.production      (live customer-serving deploy)
# All three files are GIT-IGNORED. Copy this template to whichever one you
# need on the target host and fill in real values (or CI/CD-inject them).
#
# Activate one env at boot:
#     export TFAI_ENV=local          # → loads backend/.env.local
#     export TFAI_ENV=development    # → loads backend/.env.development
#     export TFAI_ENV=production     # → loads backend/.env.production
# =============================================================================

# ---- Gemini / Vertex AI ----
#   GOOGLE_GENAI_USE_VERTEXAI=True   → Vertex AI (paid, uses ADC).
#                                       Required for development + production.
#   GOOGLE_GENAI_USE_VERTEXAI=False  → AI Studio (free tier). Local-only.
GOOGLE_GENAI_USE_VERTEXAI=True
GEMINI_MODEL=gemini-2.5-flash

# Vertex AI project (when USE_VERTEXAI=True).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# AI Studio API key (when USE_VERTEXAI=False). MUST stay blank in dev + prod.
GOOGLE_API_KEY=

# ---- Phase 6 architecture (locked ON — the ONLY supported extractor) ----
# Phase 6 = single-call semantic classifier + deterministic Python row
# extractor. Phase 3 (legacy) and Phase 2 (single-call) MUST stay OFF.
USE_PHASE6=True
USE_PHASE3=False
USE_NEW_EXTRACTOR=True

# ---- Phase 3 tuning (dead code path — kept for emergency-only fallback) ----
PHASE3_MAX_PARALLEL_WORKERS=8
PHASE3_LAYER_CHUNK_THRESHOLD_TOKENS=35000
PHASE3_CHUNK_TARGET_TOKENS=30000
PHASE3_TOKENS_PER_CELL=8.0
PHASE3_MAX_ROWS_PER_SHEET=250

# ---- Django ----
SECRET_KEY=your_django_secret_key_here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# ---- Database — PostgreSQL. Leave blank to use SQLite (dev only). ----
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=

# ---- Redis — Celery queue (db=0) + API cache (db=1). ----
# Leave blank to use redis://localhost:6379/0 (local dev default).
REDIS_URL=

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:3000

# ---- Export URLs (used in generated PDFs / emails) ----
EXPORT_BASE_URL=

# ---- Operational ----
MIS_FILE_PATH=
