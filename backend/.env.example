# Gemini Configuration — DUAL MODE (Vertex AI for prod, AI Studio for dev).
#
#   GOOGLE_GENAI_USE_VERTEXAI=True   → Vertex AI (paid per token)
#                                       Requires `gcloud auth application-default login`.
#                                       Set GOOGLE_CLOUD_PROJECT + GOOGLE_CLOUD_LOCATION.
#
#   GOOGLE_GENAI_USE_VERTEXAI=False  → AI Studio (free tier available)
#                                       Get key at https://aistudio.google.com/app/apikey
#                                       Set GOOGLE_API_KEY.
#
# AI Studio FREE TIER caveats:
#   • Flash: 15 req/min, 1M tokens/min, 1500 req/day
#   • Pro:   2 req/min — too tight for Phase 3 parallel imports
#   • Free tier may use prompts to improve Google models — DO NOT use for
#     real customer AIF data in production
GOOGLE_GENAI_USE_VERTEXAI=False
GOOGLE_API_KEY=your-ai-studio-api-key
GEMINI_MODEL=gemini-2.5-flash

# Vertex AI fallback (only used when GOOGLE_GENAI_USE_VERTEXAI=True)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Phase 6 — single-call semantic classifier + deterministic Python row
# extractor. Current-generation architecture; must be default-on.
USE_PHASE6=True

# Phase 3 (Flavor A + Flavor B parallel layers) — legacy. Only set True
# as emergency fallback; costs multiple Gemini calls per import.
USE_PHASE3=False

# Single-call extractor (Phase 2). Emergency-only floor when both Phase 6
# and Phase 3 are disabled.
USE_NEW_EXTRACTOR=True

# Phase 3 tuning (all optional — sensible defaults baked in).
PHASE3_MAX_PARALLEL_WORKERS=8
PHASE3_LAYER_CHUNK_THRESHOLD_TOKENS=35000
PHASE3_CHUNK_TARGET_TOKENS=30000
PHASE3_TOKENS_PER_CELL=8.0
PHASE3_MAX_ROWS_PER_SHEET=250

# Django
SECRET_KEY=your_django_secret_key_here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — PostgreSQL (production). Leave blank to use SQLite (dev only).
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=

# Redis — used for Celery task queue (db=0) and API response cache (db=1).
# Leave blank to use redis://localhost:6379/0 (local dev default).
REDIS_URL=

# Excel MIS File (optional - can be uploaded via UI)
MIS_FILE_PATH=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8080,http://127.0.0.1:8080
