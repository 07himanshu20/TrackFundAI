# =============================================================================
# Frontend build-time env template (Amplify / CI).
# ---------------------------------------------------------------------------
# The runtime SPA reads window.APP_CONFIG set by frontend/env.js. Real
# per-environment JS is committed as env.local.js / env.development.js /
# env.production.js — see frontend/env.example.js for the template.
#
# THIS FILE only exists as documentation for CI systems (e.g. Amplify Console)
# that read .env-style key/value pairs at build time. Real .env.<env> files
# should be gitignored on those systems too.
# =============================================================================

# Backend API base URL (no trailing slash, includes /api)
API_BASE=

# Plain backend origin (no /api) — used by SSE endpoints (data-upload stream)
API_ORIGIN=

# 'local' | 'development' | 'production'
ENVIRONMENT=

# 'true' | 'false' — toggles verbose console logging
DEBUG=
