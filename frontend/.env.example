# =============================================================================
# Frontend env-var template. Copy this file to .env.development or .env.production
# and fill in the values for your target environment.
# =============================================================================

# Backend API base URL (must end without a trailing slash, must include /api)
API_BASE=

# Plain origin (no /api) — used by SSE endpoints (data-upload import stream)
API_ORIGIN=

# 'development' | 'staging' | 'production'
ENVIRONMENT=

# 'true' | 'false' — toggles verbose console logging
DEBUG=
